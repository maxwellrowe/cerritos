<parameter name="PageCSS" type="text" rows="10" group="Administrators" prompt="Page CSS" alt="(Admin) What is the page CSS to change the header and bottom feature backgrounds?">/*---Bottom Feature on Landing Page---*/

.landing-page #BottomFeature {
    background: url(/_resources/images/landing/cerritos-landing-PanelAd.jpg) no-repeat;
    height: 45.071rem;
    position: relative;
    margin: 0 auto 3.214rem;
    border: 1px solid #ccc;
    max-width: 100%;
}

@media (max-width: 768px) {
	.landing-page #BottomFeature {
    		background: url(/_resources/images/landing/cerritos-landing-PanelAd_700.jpg) no-repeat;
		background-size: contain;
	}
}


/*-----Top Panel on Landing Page---*/

#about-header {
    background: url(/_resources/images/landing/cerritos-landing-top.jpg) no-repeat;
    background-size: 100%;
    width: 92.85714rem;
    height: 35.92857rem;
    margin-bottom: 40px;
    border: 1px solid #ccc;
    max-width: 100%;
    position: relative;
}

@media (max-width: 768px) {
	#about-header {
    		background: url(/_resources/images/landing/cerritos-landing-top_700.jpg) no-repeat;
		background-size: contain;
	}
}
